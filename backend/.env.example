# ── Neo4j AuraDB ─────────────────────────────────────────────────────────────
NEO4J_URI=           # neo4j+s://xxxxx.databases.neo4j.io
NEO4J_USERNAME=      # neo4j
NEO4J_PASSWORD=      # your AuraDB password

# ── AI providers ─────────────────────────────────────────────────────────────
# At least one AI provider is required for /v1/plan and /v1/bridge.
# Gemini is the default and most generous free tier (1,500 req/day, 1M TPM).
GEMINI_API_KEY=      # https://aistudio.google.com/app/apikey
GEMINI_MODEL=gemini-2.0-flash

# Groq — fast fallback for low-latency queries (free, no card required)
GROQ_API_KEY=        # https://console.groq.com

# Anthropic — optional paid fallback
ANTHROPIC_API_KEY=

# AI_PROVIDER=auto   # auto | gemini | groq | anthropic | rocketride_sdk | rocketride_http

# ── Supabase (required for Milestone 4: Auth & Persistent Accounts) ───────────
SUPABASE_URL=               # https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=  # Project Settings → API → service_role key (keep secret!)
SUPABASE_JWT_SECRET=        # Project Settings → API → JWT Settings → JWT Secret

# ── Session cache ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_URL=   # Upstash console → Redis → REST URL
UPSTASH_REDIS_TOKEN= # Upstash console → Redis → REST token

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=      # https://resend.com/api-keys (3k free emails/month)

# ── LinkedIn OAuth ────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/v1/auth/linkedin/callback

# ── RocketRide (optional legacy pipelines) ────────────────────────────────────
ROCKETRIDE_URI=
ROCKETRIDE_APIKEY=
ROCKETRIDE_HTTP_COMPLETION_URL=

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
