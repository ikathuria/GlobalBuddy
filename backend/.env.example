NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=

# AI — set at least one path (Gemini recommended for this repo)
AI_PROVIDER=auto
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional alternates (when not using Gemini)
ANTHROPIC_API_KEY=
# RocketRide SDK path (recommended RocketRide integration)
ROCKETRIDE_URI=
ROCKETRIDE_APIKEY=
ROCKETRIDE_GEMINI_KEY=
ROCKETRIDE_PLAN_PIPELINE=../pipelines/globaldost.plan.pipe
ROCKETRIDE_BRIDGE_PIPELINE=../pipelines/globaldost.bridge.pipe
# Legacy RocketRide HTTP completion endpoint path
ROCKETRIDE_HTTP_COMPLETION_URL=

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
